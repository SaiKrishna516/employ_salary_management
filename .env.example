# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in all required values before running
# docker compose up.  Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Strong random password for the production DB user.
# Generate one: openssl rand -hex 32
POSTGRES_PASSWORD=changeme_use_a_strong_password

# ── Rails backend ─────────────────────────────────────────────────────────────
# Found in backend/config/master.key  (do NOT commit that file).
# Or generate a new one: cd backend && bundle exec rails credentials:edit
RAILS_MASTER_KEY=your_master_key_here

# CORS — the full URL of your frontend (no trailing slash).
# For local Docker: http://localhost
# For production:   https://yourdomain.com
ALLOWED_ORIGIN=http://localhost

# Puma concurrency (set to number of CPU cores available).
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5

# Optional: override host ports (defaults shown)
# BACKEND_PORT=3001
# FRONTEND_PORT=80

# ── React frontend ────────────────────────────────────────────────────────────
# Full URL to the Rails API — used at Vite build time (baked into JS bundle).
# For local Docker:  http://localhost:3001/api/v1
# For production:    https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1
